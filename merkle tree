# 3. EXAMPLE USAGE
# ============================================================

if __name__ == "__main__":

    logs = [
        "User login successful",
        "File accessed /etc/passwd",
        "Kernel boot completed",
        "Error disk read failure",
        "Network connection established"
    ]

    tree = MerkleTree(logs)

    # Root
    root = tree.get_root()
    print(" MERKLE ROOT:")
    print(root)

    # Show tree
    tree.print_tree()

    # Proof for log index 2
    index = 2
    proof = tree.get_proof(index)

    print("\n MERKLE PROOF:")
    print(proof)

    # Verification
    result = tree.verify_proof(logs[index], proof, root)

    print("\n VERIFICATION RESULT:", result)
